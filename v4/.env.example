# V4 bot environment

WS_URL=wss://your-mainnet-ws
MAINNET_RPC_URL=https://your-mainnet-rpc
BOT_PK=
ARB_CONTRACT=
DRY_RUN=true

CHAIN_ID=1
LOAN_SIZES_USDC=5000,10000,25000
SLIPPAGE_BPS=50
MIN_PROFIT_BPS=10
ESTIMATED_ARB_GAS=1100000
MAX_GAS_PRICE_GWEI=120
MULTI_BLOCK_TARGETS=1
BUILDER_TIP_WEI=0

# 0 = Aave, 1 = Balancer vault flash
FLASH_SOURCE=0
SCAN_STRATEGY=trihop

# Mempool backrun hints (optional, default off)
USE_MEMPOOL=false
MEMPOOL_MIN_ETH=1

HEALTH_PORT=8789
HEALTH_BIND=127.0.0.1
HEALTH_TOKEN=
METRICS_ENABLED=true

FLASHBOTS_RELAY=https://relay.flashbots.net
FLASHBOTS_AUTH_PK=

DEPLOYER_PK=
ETHERSCAN_API_KEY=
